  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^25.9.3",
    "rimraf": "^6.1.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
