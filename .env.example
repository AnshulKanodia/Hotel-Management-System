# Environment Variables for Hotel Management System

# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────────
# Replace <username>, <password>, and <cluster-url> with your Atlas credentials
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/hotel_management?retryWrites=true&w=majority

# Example:
# MONGO_URI=mongodb+srv://anshul:mypassword@cluster0.abcde.mongodb.net/hotel_db?retryWrites=true&w=majority
