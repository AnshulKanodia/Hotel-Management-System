            "dashboard"
          ]
        },
        "description": "Fetch high-level overview metrics compiled using MongoDB aggregation pipelines."
      },
      "response": []
    },
    {
      "name": "11. Top Customers Report",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/reports/top-customers",
          "host": [
            "{{base_url}}"
          ],
          "path": [
